ENVIRONMENT=development
DEBUG=false
ENABLE_API_DOCS=true
SEED_DEMO_DATA=false

DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>
JWT_SECRET_KEY=<generate-a-random-32-byte-or-longer-secret>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_SECURE=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Required only when SEED_DEMO_DATA=true
SEED_ADMIN_PASSWORD=<dev-admin-password>
SEED_MANAGER_PASSWORD=<dev-manager-password>
SEED_CASHIER_PASSWORD=<dev-cashier-password>
SEED_STOCK_PASSWORD=<dev-stock-password>
